      "name": "List all RDS instances",
      "description": "Verify ListInstances returns all RDS instances in the region",
      "command": "hcloud RDS ListInstances --cli-region=cn-north-4",
      "expected_result": "JSON response with instances array",
      "validation": "response.instances is a list",
      "mode": "CLI",
      "risk_level": "read-only",
      "requires_confirmation": false
    },
