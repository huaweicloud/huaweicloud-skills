#!/bin/bash
#===============================================================================
# interactive-e2e-test.sh — Generic End-to-End Interactive Skill Creation Test
#
# Generic test that reads any skill-creator's templates, dynamically parses
# {{VAR}} placeholders, generates smart default values from the skill's own
# metadata, scaffolds a complete skill, validates it, and tests it.
#
# Usage:
#   bash scripts/interactive-e2e-test.sh <skill-creator-path> \
#     --test-vars <json-file>  (optional: override auto-generated vars)
#     [--output <report-path>]
#     [--dry-run]
#
# Works with any skill-creator that has:
#   templates/SKILL.md.template  (with {{VAR}} placeholders)
#===============================================================================

set -euo pipefail

CREATOR_PATH=""
TEST_VARS_FILE=""
OUTPUT="./interactive-e2e-report.yaml"
DRY_RUN=false

PASS_COUNT=0
FAIL_COUNT=0
WARN_COUNT=0
RESULTS=()

usage() {
  cat <<'USAGE'
Usage: bash scripts/interactive-e2e-test.sh <skill-creator-path> [options]

Options:
  --test-vars <file>    JSON file with preset answers (overrides auto-generate)
  --output <path>       Report output path (default: ./interactive-e2e-report.yaml)
  --dry-run             Parse only, don't scaffold or validate
USAGE
  exit 1
}

if [ $# -lt 1 ]; then usage; fi
CREATOR_PATH="$1"
shift

while [ $# -gt 0 ]; do
  case "$1" in
    --test-vars) TEST_VARS_FILE="$2"; shift 2 ;;
    --output)    OUTPUT="$2"; shift 2 ;;
    --dry-run)   DRY_RUN=true; shift ;;
    *) usage ;;
  esac
done

log_pass() { echo "[PASS] [e2e] $1"; PASS_COUNT=$((PASS_COUNT + 1)); RESULTS+=("PASS|$1"); }
log_fail() { echo "[FAIL] [e2e] $1"; FAIL_COUNT=$((FAIL_COUNT + 1)); RESULTS+=("FAIL|$1"); }
log_warn() { echo "[WARN] [e2e] $1"; WARN_COUNT=$((WARN_COUNT + 1)); RESULTS+=("WARN|$1"); }
log_info() { echo "[INFO] [e2e] $1"; }

echo "============================================"
echo "  Interactive E2E Test — Skill Creation"
echo "============================================"
echo ""

#===============================================================================
# Step 0: Read the skill-under-test's metadata to generate smart defaults
#===============================================================================
log_info "=== Step 0: Reading skill metadata ==="

SKILL_MD="$CREATOR_PATH/SKILL.md"
CREATOR_NAME=""
CREATOR_DESC=""
CREATOR_TAGS=""
CREATOR_SERVICE=""
CREATOR_DOMAIN=""

if [ -f "$SKILL_MD" ]; then
  CREATOR_NAME=$(grep '^name:' "$SKILL_MD" | head -1 | awk '{print $2}' | tr -d '"'"'" || echo "unknown-creator")
  CREATOR_DESC=$(grep '^description:' "$SKILL_MD" | head -1 | sed 's/description: *|//' | xargs || echo "")
  CREATOR_TAGS=$(grep '^tags:' "$SKILL_MD" | head -1 | sed 's/tags: *\[//;s/\].*//' | xargs || echo "")
  log_pass "Read creator metadata: $CREATOR_NAME"

  # Extract probable service and domain from tags or name
  for tag in $(echo "$CREATOR_TAGS" | tr ',' ' '); do
    tag=$(echo "$tag" | tr -d '"' | xargs)
    svc=$(echo "$tag" | tr '[:lower:]' '[:upper:]')
    case "$svc" in
      ECS|VPC|OBS|RDS|IAM|CCE|ELB|DNS|SMN|LTS|CES|BSS|DCS|DMS|KMS|DEW|NAT|VPN|AS|IMS|EVS|SFS|DDS|GAUSSDB|WAF|CBR|AOM)
        [ -z "$CREATOR_SERVICE" ] && CREATOR_SERVICE="$svc"
        ;;
    esac
  done
  [ -z "$CREATOR_SERVICE" ] && CREATOR_SERVICE="ECS"  # safest default
  log_info "  Detected service: $CREATOR_SERVICE"
fi

#===============================================================================
# Step 1: Validate templates and dynamically parse {{VAR}} placeholders
#===============================================================================
echo ""
log_info "=== Step 1: Template Analysis ==="

TEMPLATES_DIR="$CREATOR_PATH/templates"
if [ ! -d "$TEMPLATES_DIR" ]; then
  log_fail "Templates directory not found at $TEMPLATES_DIR"
  echo ""
  echo "=== Summary: PASS=$PASS_COUNT FAIL=$FAIL_COUNT ==="
  exit 1
fi
log_pass "Templates directory found"

# Find all templates, check for {{VAR}} patterns
declare -a TEMPLATE_FILES=()
TEMPLATE_COUNT=0
VARS_SEEN=""
while IFS= read -r -d '' tmpl; do
  TEMPLATE_FILES+=("$tmpl")
  TEMPLATE_COUNT=$((TEMPLATE_COUNT + 1))
  log_pass "Template: $(basename "$tmpl")"
done < <(find "$TEMPLATES_DIR" -type f -print0 2>/dev/null)

# Parse all {{VAR}} patterns from all template files
VARS_JSON="{}"
if [ $TEMPLATE_COUNT -gt 0 ]; then
  VARS_JSON=$(python3 -c "
import json, glob, re, os

tmpl_dir = '$TEMPLATES_DIR'
all_vars = set()

# Collect all {{VAR}} patterns across all templates
for root, dirs, files in os.walk(tmpl_dir):
    for f in files:
        fpath = os.path.join(root, f)
        try:
            with open(fpath) as fh:
                content = fh.read()
            for m in re.finditer(r'\{\{([A-Z_][A-Z_0-9]*)\}\}', content):
                all_vars.add(m.group(1))
        except: pass

print(json.dumps(sorted(list(all_vars))))
" 2>&1) || VARS_JSON="[]"

VARS_LIST=()
if echo "$VARS_JSON" | python3 -c "import sys,json; json.load(sys.stdin)" &>/dev/null 2>&1; then
  VARS_LIST=($(echo "$VARS_JSON" | python3 -c "import sys,json; [print(v) for v in json.load(sys.stdin)]" 2>/dev/null))
fi

VARS_COUNT=${#VARS_LIST[@]}
log_info "  Found $VARS_COUNT unique template variables: $(echo "${VARS_LIST[*]}" | tr ' ' ', ')"
[ $VARS_COUNT -eq 0 ] && log_warn "No {{VAR}} placeholders found — templates may use different format"

#===============================================================================
# Step 2: Generate smart default values for all template variables
#===============================================================================
echo ""
log_info "=== Step 2: Generating Test Values ==="

# Use user-provided vars if given
if [ -n "$TEST_VARS_FILE" ] && [ -f "$TEST_VARS_FILE" ]; then
  USER_VARS=$(cat "$TEST_VARS_FILE")
  log_info "Loaded user-provided test variables from: $TEST_VARS_FILE"
else
  USER_VARS="{}"
fi

# Generate smart defaults based on detected service
SERVICE_LOW=$(echo "$CREATOR_SERVICE" | tr '[:upper:]' '[:lower:]')
RESOURCE="server"
case "$CREATOR_SERVICE" in
  VPC)  RESOURCE="vpc" ;;
  OBS)  RESOURCE="bucket" ;;
  RDS)  RESOURCE="instance" ;;
  IAM)  RESOURCE="user" ;;
  CCE)  RESOURCE="cluster" ;;
  ELB)  RESOURCE="loadbalancer" ;;
  DNS)  RESOURCE="zone" ;;
  BSS)  RESOURCE="account" ;;
  NAT)  RESOURCE="gateway" ;;
esac

# Write the generator to a temp file to avoid quoting hell
cat > /tmp/hermes-e2e-gen.py << 'PYEOF'
import json, sys

all_vars = json.loads(sys.argv[1])
user_vars = json.loads(sys.argv[2])
svc = sys.argv[3]
svc_low = svc.lower()
res = sys.argv[4]
creator_name = sys.argv[5]
skill_name = 'huawei-cloud-' + svc_low + '-' + res + '-manage'

defaults = {}
for v in all_vars:
    if v == 'SKILL_NAME':   defaults[v] = skill_name
    elif v == 'TITLE':      defaults[v] = svc + ' ' + res.title() + ' Manager'
    elif v == 'SERVICE':    defaults[v] = svc
    elif v == 'SERVICE_LOW': defaults[v] = svc_low
    elif v == 'RESOURCE':   defaults[v] = res
    elif v == 'DOMAIN':
        if svc in ('ECS','AS','IMS'): defaults[v] = 'compute'
        elif svc in ('VPC','ELB','NAT','VPN','EIP'): defaults[v] = 'network'
        elif svc in ('OBS','EVS','SFS'): defaults[v] = 'storage'
        elif svc in ('RDS','DDS','GAUSSDB','DCS'): defaults[v] = 'database'
        elif svc in ('IAM','WAF','CBR'): defaults[v] = 'security'
        elif svc in ('CES','LTS','AOM'): defaults[v] = 'monitoring'
        else: defaults[v] = 'middleware'
    elif v == 'TAGS':       defaults[v] = json.dumps(['huawei-cloud', svc_low, res, 'management'])
    elif v == 'FUNCTIONAL_POSITIONING': defaults[v] = 'Manage and monitor ' + svc + ' ' + res + 's'
    elif v == 'TRIGGER_CONDITIONS': defaults[v] = '管理' + svc_low + ', 查看' + svc_low + ', manage ' + svc_low + ', ' + svc_low + ' management'
    elif v == 'PREREQUISITE': defaults[v] = 'Requires hcloud CLI with ' + svc + ' ReadOnlyAccess policy'
    elif v == 'OVERVIEW':   defaults[v] = 'A skill that manages Huawei Cloud ' + svc + ' ' + res + 's'
    elif v == 'STEP_1_TITLE': defaults[v] = 'List ' + svc + ' ' + res + 's'
    elif v == 'OPERATION_1': defaults[v] = 'List' + res[0].upper() + res[1:] + 's'
    elif v.startswith('PARAMS_1'): defaults[v] = '--limit=10'
    elif v == 'ACTION_1':   defaults[v] = svc_low + ':' + res + 's:list'
    elif v == 'STEP_2_TITLE': defaults[v] = 'Show ' + res + ' Detail'
    elif v == 'OPERATION_2': defaults[v] = 'Show' + res[0].upper() + res[1:]
    elif v.startswith('PARAMS_2'): defaults[v] = '--' + res + '_id={instance_id}'
    elif v == 'ACTION_2':   defaults[v] = svc_low + ':' + res + 's:get'
    elif v == 'STEP_3_TITLE': defaults[v] = 'Monitor ' + res + ' Status'
    elif v == 'OPERATION_3': defaults[v] = 'Show' + res[0].upper() + res[1:]
    elif v.startswith('PARAMS_3'): defaults[v] = '--' + res + '_id={instance_id}'
    elif v == 'ACTION_3':   defaults[v] = svc_low + ':' + res + 's:get'
    elif v == 'EXAMPLE_1_TITLE': defaults[v] = 'List all ' + res + 's'
    elif v == 'EXAMPLE_1_OPERATION': defaults[v] = 'List' + res[0].upper() + res[1:] + 's'
    elif v.startswith('EXAMPLE_1_PARAMS'): defaults[v] = '--limit=20'
    elif v == 'EXAMPLE_2_TITLE': defaults[v] = 'Show ' + res + ' details'
    elif v == 'EXAMPLE_2_OPERATION': defaults[v] = 'Show' + res[0].upper() + res[1:]
    elif v.startswith('EXAMPLE_2_PARAMS'): defaults[v] = '--' + res + '_id=i-12345'
    elif v == 'EXAMPLE_3_TITLE': defaults[v] = 'Verify ' + svc + ' connectivity'
    elif v == 'EXAMPLE_3_OPERATION': defaults[v] = 'Show' + res[0].upper() + res[1:]
    elif v.startswith('EXAMPLE_3_PARAMS'): defaults[v] = '--' + res + '_id=i-12345'
    elif v == 'EDGE_CASE_1': defaults[v] = res.title() + ' not found'
    elif v == 'EDGE_CASE_1_SOLUTION': defaults[v] = 'Return error message indicating ' + res + ' not found'
    elif v == 'EDGE_CASE_2': defaults[v] = 'Empty ' + res + ' list'
    elif v == 'EDGE_CASE_2_SOLUTION': defaults[v] = 'Return empty result with info message'
    elif v == 'EDGE_CASE_3': defaults[v] = 'Insufficient permissions'
    elif v == 'EDGE_CASE_3_SOLUTION': defaults[v] = 'Guide user to check IAM policy'
    elif v == 'VERIFY_OPERATION': defaults[v] = 'List' + res[0].upper() + res[1:] + 's'
    elif v.startswith('VERIFY_PARAMS'): defaults[v] = '--limit=1'
    elif v == 'RESOURCE_TYPE': defaults[v] = svc + ' ' + res
    elif v == 'BILLING_MODEL': defaults[v] = 'pay-per-use'
    elif v == 'ESTIMATED_COST': defaults[v] = 'varies by specification'
    elif v == 'DELETE_REQUIRES_MFA': defaults[v] = 'No'
    elif v == 'MFA_DESCRIPTION': defaults[v] = 'No MFA required for read-only operations'
    elif v == 'SCRIPT_USAGE_SECTION': defaults[v] = 'Uses hcloud CLI commands directly'
    elif v == 'VERSION':    defaults[v] = '1.0.0'

result = {**defaults, **user_vars}
with open('/tmp/hermes-e2e-vars.json', 'w') as f:
    json.dump(result, f, indent=2)
print(json.dumps(result, indent=2))
PYEOF

python3 /tmp/hermes-e2e-gen.py "$VARS_JSON" "$USER_VARS" "$CREATOR_SERVICE" "$RESOURCE" "$CREATOR_NAME" 2>&1 || {
  log_fail "Failed to generate variable values"
  exit 1
}

VARS_JSON=$(cat /tmp/hermes-e2e-vars.json)
TEST_SKILL_NAME=$(echo "$VARS_JSON" | python3 -c "import sys,json; print(json.load(sys.stdin).get('SKILL_NAME','unknown'))" 2>/dev/null || echo "unknown")

log_info "Test skill to create: $TEST_SKILL_NAME (service: $CREATOR_SERVICE)"
log_info "Generated ${VARS_COUNT} variable values"

if [ "$DRY_RUN" = true ]; then
  log_info "DRY RUN: Would scaffold $TEST_SKILL_NAME in temp directory"
  log_pass "Dry run completed [required]"
  echo ""
  echo "=== Summary: PASS=$PASS_COUNT FAIL=$FAIL_COUNT ==="
  exit 0
fi

#===============================================================================
# Step 3: Scaffold skill from templates with generated/loaded values
#===============================================================================
echo ""
log_info "=== Step 3: Scaffolding Skill ==="

TMP_SKILL=$(mktemp -d /tmp/hermes-interactive-e2e-XXXXXX)
SKILL_DIR="$TMP_SKILL/$TEST_SKILL_NAME"
trap "rm -rf $TMP_SKILL" EXIT

mkdir -p "$SKILL_DIR/references" "$SKILL_DIR/scripts" "$SKILL_DIR/templates" "$SKILL_DIR/i18n/zh-CN"

# Substitute {{VAR}} in all template files
for tmpl in "${TEMPLATE_FILES[@]}"; do
  rel_name=$(echo "$tmpl" | sed "s|$TEMPLATES_DIR/||")
  base_name=$(basename "$tmpl")
  dst=""

  # Map template to destination path inside the new skill
  case "$base_name" in
    SKILL.md.template)                    dst="$SKILL_DIR/SKILL.md" ;;
    iam-policies.md.template)             dst="$SKILL_DIR/references/iam-policies.md" ;;
    dataflow-diagram.md.template)         dst="$SKILL_DIR/references/dataflow-diagram.md" ;;
    verification-method.md.template)      dst="$SKILL_DIR/references/verification-method.md" ;;
    cli-installation-guide.md.template)   dst="$SKILL_DIR/references/cli-installation-guide.md" ;;
    test-report.md.template)              dst="$SKILL_DIR/references/test-report.md" ;;
    i18n-zh-CN-SKILL_CN.md.template)     dst="$SKILL_DIR/i18n/zh-CN/SKILL_CN.md" ;;
    *)                                    dst="$SKILL_DIR/references/$base_name" ;;
  esac

  # Substitute {{VAR}} using the merged vars JSON
  python3 -c "
import json, sys

with open('$tmpl') as f:
    content = f.read()

with open('/tmp/hermes-e2e-vars.json') as f:
    data = json.load(f)

for key, val in data.items():
    content = content.replace('{{' + key + '}}', str(val))

with open('$dst', 'w') as f:
    f.write(content)
" 2>&1 && log_pass "Rendered: $(basename "$dst")" || log_fail "Failed to render: $(basename "$tmpl")"
done

# Copy static references from creator (best-effort)
for refdir in "references" "scripts"; do
  if [ -d "$CREATOR_PATH/$refdir" ]; then
    for f in "$CREATOR_PATH/$refdir/"*; do
      bname=$(basename "$f")
      # Don't overwrite rendered files
      [ -f "$SKILL_DIR/$refdir/$bname" ] && continue
      cp "$f" "$SKILL_DIR/$refdir/" 2>/dev/null && chmod +x "$SKILL_DIR/$refdir/$bname" 2>/dev/null || true
    done
  fi
done

# Verify directory structure
STRUCTURE_OK=true
for dir in references scripts templates i18n; do
  if [ -d "$SKILL_DIR/$dir" ]; then
    log_pass "Directory $dir/ created"
  else
    log_fail "Directory $dir/ missing"
    STRUCTURE_OK=false
  fi
done

if [ -f "$SKILL_DIR/SKILL.md" ]; then
  log_pass "SKILL.md created ($(wc -l < "$SKILL_DIR/SKILL.md") lines)"
else
  log_fail "SKILL.md missing"
  STRUCTURE_OK=false
fi

log_info "Scaffolded skill at: $SKILL_DIR"
$STRUCTURE_OK && log_pass "Skill structure verified [required]" || log_fail "Skill structure incomplete [required]"

if ! $STRUCTURE_OK; then
  echo ""
  echo "=== Summary: PASS=$PASS_COUNT FAIL=$FAIL_COUNT ==="
  exit 1
fi

#===============================================================================
# Step 4: Validate created skill
#===============================================================================
echo ""
log_info "=== Step 4: Validate Created Skill ==="

if [ -f "$SKILL_DIR/scripts/validate-skill.sh" ]; then
  if bash "$SKILL_DIR/scripts/validate-skill.sh" "$SKILL_DIR" --phase all 2>&1; then
    log_pass "Skill validation: all checks passed [required]"
  else
    log_fail "Skill validation: some checks failed [required]"
  fi
else
  # Manual fallback validation
  for field in "name" "description" "version" "tags"; do
    grep -q "^$field:" "$SKILL_DIR/SKILL.md" 2>/dev/null && log_pass "Frontmatter '$field' present" || log_fail "Frontmatter '$field' missing"
  done
  for section in "Overview" "Prerequisites" "Main Steps" "Edge Cases" "References"; do
    grep -qi "^## $section" "$SKILL_DIR/SKILL.md" 2>/dev/null && log_pass "Section '$section' present" || log_fail "Section '$section' missing"
  done
  for s in "$SKILL_DIR/scripts/"*.sh; do
    [ -x "$s" ] && log_pass "Script $(basename "$s") executable" || log_fail "Script $(basename "$s") not executable"
  done
fi

#===============================================================================
# Step 5: Test CLI commands in created skill
#===============================================================================
echo ""
log_info "=== Step 5: Test Created Skill CLI Commands ==="

if [ -f "$SKILL_DIR/scripts/test-cli-commands.sh" ]; then
  if bash "$SKILL_DIR/scripts/test-cli-commands.sh" "$SKILL_DIR" --region cn-north-4 2>&1; then
    log_pass "CLI command test: all passed [required]"
  else
    log_fail "CLI command test: some failed [required]"
  fi
else
  log_warn "test-cli-commands.sh not available — CLI test skipped"
fi

#===============================================================================
# Step 6: Verify created skill references match the test answers
#===============================================================================
echo ""
log_info "=== Step 6: Verify Skill Content ==="

# Check service name appears in rendered SKILL.md
if grep -qi "$CREATOR_SERVICE" "$SKILL_DIR/SKILL.md" 2>/dev/null; then
  log_pass "SKILL.md references service '$CREATOR_SERVICE'"
else
  log_fail "SKILL.md missing reference to service '$CREATOR_SERVICE'"
fi

# Check first operation
OP1=$(echo "$VARS_JSON" | python3 -c "import sys,json; print(json.load(sys.stdin).get('OPERATION_1',''))" 2>/dev/null || true)
if [ -n "$OP1" ] && grep -qi "$OP1" "$SKILL_DIR/SKILL.md" 2>/dev/null; then
  log_pass "SKILL.md includes CLI operation '$OP1'"
else
  log_warn "SKILL.md may not include operation '$OP1'"
fi

# Check trigger conditions
TRIGGERS=$(echo "$VARS_JSON" | python3 -c "import sys,json; print(json.load(sys.stdin).get('TRIGGER_CONDITIONS',''))" 2>/dev/null || true)
FIRST_TRIGGER=$(echo "$TRIGGERS" | cut -d',' -f1 | xargs)
if [ -n "$FIRST_TRIGGER" ] && grep -qi "$(echo "$FIRST_TRIGGER" | sed 's/"/ /g')" "$SKILL_DIR/SKILL.md" 2>/dev/null; then
  log_pass "SKILL.md includes trigger '$FIRST_TRIGGER'"
else
  log_warn "Trigger '$FIRST_TRIGGER' may not appear in SKILL.md"
fi

#===============================================================================
# Final: Generate Report
#===============================================================================
echo ""
echo "=== E2E Interactive Test Summary ==="
echo "PASS: $PASS_COUNT | FAIL: $FAIL_COUNT | WARN: $WARN_COUNT"

cat > "$OUTPUT" << REPORTEOF
interactive_e2e_test_report:
  skill_name: "$TEST_SKILL_NAME"
  template_source: "$CREATOR_NAME"
  timestamp: $(date -u +"%Y-%m-%dT%H:%M:%SZ")
  pass_count: $PASS_COUNT
  fail_count: $FAIL_COUNT
  warn_count: $WARN_COUNT
  results:
REPORTEOF

for r in "${RESULTS[@]}"; do
  s=$(echo "$r" | cut -d'|' -f1)
  d=$(echo "$r" | cut -d'|' -f2-)
  echo "    - status: $s" >> "$OUTPUT"
  echo "      description: \"$d\"" >> "$OUTPUT"
done

rm -f /tmp/hermes-e2e-vars.json
log_pass "Interactive E2E test report generated: $OUTPUT"

if [ $FAIL_COUNT -gt 0 ]; then
  echo "Status: FAIL"
  exit 1
else
  echo "Status: PASS"
  exit 0
fi
